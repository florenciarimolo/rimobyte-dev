---
/**
 * LandingBackground.astro
 *
 * Reusable background component for service landing pages.
 * Respects the user's light/dark theme preference via Tailwind's `dark:` class
 * on <html>. Injects decorative glow blobs that are subtler in light mode.
 */
---

<style is:inline>
  #root {
    position: relative;
    z-index: 1;
  }
  .grecaptcha-badge {
    z-index: 9999 !important;
  }
  .landing-bg-glow {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 900px;
    background: rgba(88, 28, 135, 0.07);
    filter: blur(130px);
    border-radius: 9999px;
    pointer-events: none;
    z-index: 0;
  }
  .landing-bg-glow-2 {
    position: fixed;
    top: 10%;
    left: -5%;
    width: 600px;
    height: 600px;
    background: rgba(147, 51, 234, 0.05);
    filter: blur(110px);
    border-radius: 9999px;
    pointer-events: none;
    z-index: 0;
    animation: landing-pulse 5s ease-in-out infinite;
  }
  .landing-bg-glow-3 {
    position: fixed;
    bottom: 10%;
    right: -5%;
    width: 600px;
    height: 600px;
    background: rgba(37, 99, 235, 0.04);
    filter: blur(110px);
    border-radius: 9999px;
    pointer-events: none;
    z-index: 0;
    animation: landing-pulse 5s ease-in-out infinite;
    animation-delay: 2s;
  }
  html.dark .landing-bg-glow {
    background: rgba(88, 28, 135, 0.20);
  }
  html.dark .landing-bg-glow-2 {
    background: rgba(147, 51, 234, 0.10);
  }
  html.dark .landing-bg-glow-3 {
    background: rgba(37, 99, 235, 0.08);
  }
  @keyframes landing-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
</style>

<div class="landing-bg-glow" aria-hidden="true"></div>
<div class="landing-bg-glow-2" aria-hidden="true"></div>
<div class="landing-bg-glow-3" aria-hidden="true"></div>
