---
export interface Props {
  rating: number;
  reviewCount: number;
  name?: string;
  url?: string;
}

const { 
  rating = 4.9, 
  reviewCount = 12, 
  name = "RimoByte - Desarrollo Web Freelance",
  url = "https://rimobyte.com" 
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": name,
  "url": url,
  "image": `${url}/assets/images/programadora-web.webp`,
  "telephone": "+34684713743",
  "email": "info@rimobyte.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barcelona",
    "addressRegion": "Cataluña",
    "addressCountry": "ES"
  },
  "priceRange": "€€",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": rating.toFixed(1),
    "reviewCount": reviewCount,
    "bestRating": "5",
    "worstRating": "1"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
