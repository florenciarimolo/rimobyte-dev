---

export interface Props {
  type: 'person' | 'website' | 'professionalService';
  locale?: string;
}

const { type, locale = 'es' } = Astro.props;
const siteUrl = 'https://rimobyte.com';
const isEs = locale === 'es';

let structuredData: any = {};

if (type === 'person') {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Florencia Rímolo",
    "alternateName": "RimoByte",
    "url": siteUrl,
    "image": `${siteUrl}/assets/images/programadora-web.webp`,
    "jobTitle": isEs ? "Desarrolladora Web Freelance" : "Freelance Web Developer",
    "worksFor": {
      "@type": "Organization",
      "name": "RimoByte"
    },
    "sameAs": [
      "https://linkedin.com/in/florencia-rimolofigueira",
      "https://www.instagram.com/rimobyte"
    ],
    "email": "info@rimobyte.com",
    "telephone": "+34684713743",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "ES",
      "addressLocality": "Barcelona",
      "addressRegion": "Cataluña"
    },
    "knowsLanguage": ["es", "en"],
    "knowsAbout": [
      "WordPress",
      "WooCommerce",
      "Shopify",
      "Vue.js",
      "Nuxt",
      "Astro",
      "React",
      "TypeScript",
      "JavaScript",
      "SEO",
      "Web Performance Optimization",
      "E-commerce Development",
      "Web Development"
    ]
  };
} else if (type === 'website') {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "RimoByte",
    "url": siteUrl,
    "description": isEs
      ? "Desarrolladora web freelance en España. WordPress, tiendas online WooCommerce y aplicaciones web a medida para pymes y autónomos. Precios claros desde 500 €."
      : "Freelance web developer in Spain. WordPress, WooCommerce online stores and custom web apps for SMBs and freelancers. Clear pricing from €500.",
    "author": {
      "@type": "Person",
      "name": "Florencia Rímolo"
    },
    "inLanguage": isEs ? ["es-ES", "en"] : ["en", "es-ES"]
  };
} else if (type === 'professionalService') {
  const services = isEs ? [
    { name: "Web corporativa WordPress", desc: "Sitios profesionales, rápidos y fáciles de mantener para tu negocio.", price: "800" },
    { name: "Tienda online WooCommerce/Shopify", desc: "E-commerce adaptado a tu negocio con pasarelas de pago y gestión de stock.", price: "1200" },
    { name: "Aplicación web a medida", desc: "Apps con Vue, Nuxt o Astro para proyectos que necesitan más que un CMS.", price: "2500" },
    { name: "Rediseño web", desc: "Moderniza tu web sin perder el posicionamiento SEO que ya tienes.", price: "600" },
    { name: "Optimización de velocidad WordPress", desc: "Mejora el rendimiento de tu WordPress y sube tu nota en PageSpeed.", price: "300" },
    { name: "Mantenimiento web", desc: "Actualizaciones, seguridad y soporte técnico continuo para tu web.", price: "40", unit: "MES" }
  ] : [
    { name: "Corporate WordPress Website", desc: "Professional, fast, easy-to-maintain business websites.", price: "800" },
    { name: "WooCommerce/Shopify Online Store", desc: "E-commerce tailored to your business with payment gateways and stock management.", price: "1200" },
    { name: "Custom Web Application", desc: "Apps with Vue, Nuxt or Astro for projects that need more than a CMS.", price: "2500" },
    { name: "Website Redesign", desc: "Modernise your website without losing your SEO rankings.", price: "600" },
    { name: "WordPress Speed Optimisation", desc: "Improve your WordPress performance and PageSpeed score.", price: "300" },
    { name: "Website Maintenance", desc: "Updates, security and ongoing technical support for your site.", price: "40", unit: "MONTH" }
  ];

  structuredData = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "RimoByte",
    "description": isEs
      ? "Desarrolladora web freelance en España. WordPress, tiendas online, rediseño web y aplicaciones a medida para pymes y autónomos. Precio fijo desde 500 €, sin intermediarios."
      : "Freelance web developer in Spain. WordPress, online stores, website redesign and custom apps for SMBs and freelancers. Fixed pricing from €500, no intermediaries.",
    "url": siteUrl,
    "image": `${siteUrl}/assets/images/programadora-web.webp`,
    "telephone": "+34684713743",
    "email": "info@rimobyte.com",
    "provider": {
      "@type": "Person",
      "name": "Florencia Rímolo",
      "jobTitle": isEs ? "Desarrolladora Web Freelance" : "Freelance Web Developer",
      "email": "info@rimobyte.com"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Barcelona",
      "addressRegion": "Cataluña",
      "addressCountry": "ES"
    },
    "areaServed": [
      { "@type": "City", "name": "Barcelona", "addressCountry": "ES" },
      { "@type": "City", "name": "Madrid", "addressCountry": "ES" },
      { "@type": "City", "name": "Valencia", "addressCountry": "ES" },
      { "@type": "City", "name": "Sevilla", "addressCountry": "ES" },
      { "@type": "City", "name": "Bilbao", "addressCountry": "ES" },
      { "@type": "City", "name": "Zaragoza", "addressCountry": "ES" },
      { "@type": "Country", "name": "Spain" }
    ],
    "serviceType": isEs
      ? ["Desarrollo WordPress", "Tienda Online WooCommerce", "Desarrollo Web a Medida", "Rediseño Web", "Optimización Velocidad WordPress", "Mantenimiento Web"]
      : ["WordPress Development", "WooCommerce Online Store", "Custom Web Development", "Website Redesign", "WordPress Speed Optimisation", "Website Maintenance"],
    "priceRange": "€€",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": isEs ? "Servicios de Desarrollo Web" : "Web Development Services",
      "itemListElement": services.map((s, i) => ({
        "@type": "Offer",
        "position": i + 1,
        "itemOffered": {
          "@type": "Service",
          "name": s.name,
          "description": s.desc
        },
        "priceSpecification": {
          "@type": "PriceSpecification",
          "minPrice": s.price,
          "priceCurrency": "EUR",
          ...((s as any).unit ? { "unitText": (s as any).unit } : {})
        }
      }))
    }
  };
}

const jsonLd = JSON.stringify(structuredData);
---

<script type="application/ld+json" set:html={jsonLd} is:inline />
