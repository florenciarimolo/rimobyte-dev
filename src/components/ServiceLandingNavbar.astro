---
/**
 * Navbar for service landing pages.
 * Respects user's light/dark theme and provides navigation back to the main site.
 */
export interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;
const isSpanish = locale === 'es';
const langPrefix = isSpanish ? '/es' : '/en';

const homeLabel = 'RimoByte';
const backLabel = isSpanish ? 'Inicio' : 'Home';
const ctaText = isSpanish ? 'Contactar' : 'Contact';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md border-b border-gray-200 dark:border-gray-800 transition-colors duration-200" id="landing-nav">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo + back link -->
      <div class="flex items-center gap-3">
        <a href={`${langPrefix}/`} class="flex items-center space-x-2 group">
          <img
            src="/favicon-96x96.png"
            alt="RimoByte"
            width="32"
            height="32"
            class="w-8 h-8 transition-opacity duration-300"
          />
          <span class="text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200 font-semibold text-lg">
            {homeLabel}
          </span>
        </a>
        <span class="hidden sm:inline text-gray-300 dark:text-gray-600" aria-hidden="true">/</span>
        <a href={`${langPrefix}/`} class="hidden sm:inline text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          {backLabel}
        </a>
      </div>

      <!-- Right side: theme switcher + CTA -->
      <div class="flex items-center gap-3">
        <!-- Theme switcher (inline Astro version) -->
        <button
          id="landing-theme-toggle"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200"
          aria-label="Toggle theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
          </svg>
        </button>

        <!-- CTA Button -->
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-5 py-2 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-full text-sm font-semibold hover:shadow-lg hover:shadow-blue-500/25 hover:scale-[1.02] transition-all duration-200"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Spacer -->
<div class="h-16"></div>

<script is:inline>
  (function() {
    var btn = document.getElementById('landing-theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var html = document.documentElement;
      var isDark = html.classList.contains('dark');
      var newTheme = isDark ? 'light' : 'dark';
      html.classList.toggle('dark', !isDark);
      document.body.classList.toggle('dark', !isDark);
      localStorage.setItem('theme', newTheme);
      window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: newTheme } }));
    });
  })();
</script>
