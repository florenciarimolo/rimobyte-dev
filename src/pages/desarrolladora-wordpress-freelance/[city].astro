---
import MainLayout from '@/layouts/MainLayout.astro';
import WordPressLandingPage from '@/components/WordPressLandingPage';
import WordPressStructuredData from '@/components/wordpress-landing/WordPressStructuredData.astro';
import { SITE_URL } from '@/constants';
import { isValidCity, getCityInfo, indexableCities, getAllowedCities } from '@/constants/cities';

export function getStaticPaths() {
  const cities = getAllowedCities();
  return Object.keys(cities).map((city) => ({ params: { city } }));
}

const { city } = Astro.params;

const normalizedCity = city?.toLowerCase();
const isValidCitySlug = normalizedCity && isValidCity(normalizedCity);

if (!isValidCitySlug) {
  return Astro.redirect('/404');
}

const cityInfo = getCityInfo(normalizedCity!);
const cityName = cityInfo!.name;
const isIndexable = indexableCities.includes(normalizedCity!);

const currentUrl = `${SITE_URL}${Astro.url.pathname}`;
const title = `Desarrollo WordPress en ${cityName} | Precio fijo desde 500€ | Sin intermediarios`;
const description = `Desarrollo web WordPress en ${cityName}. Freelance con 5 años de experiencia. Precio transparente, comunicación directa y código de calidad. Desde 500€.`;
---

<MainLayout 
  title={title}
  description={description}
  city={cityName}
>
  <meta name="robots" content={isIndexable ? "index, follow" : "noindex, follow"} />
  
  <WordPressStructuredData 
    url={currentUrl}
    city={cityName}
    cityInfo={cityInfo}
  />
  <WordPressLandingPage 
    client:only="react" 
    cityName={cityName}
    cityInfo={cityInfo}
    recaptchaSiteKey={import.meta.env.RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI'}
  />
</MainLayout>
