---
import MainLayout from '@/layouts/MainLayout.astro';
import AggregateRatingSchema from '@/components/schema/AggregateRatingSchema.astro';
import MainPage from '@/components/MainPage';

// Get reCAPTCHA site key from environment variable
// Site key is public and safe to expose to the client
const recaptchaSiteKey = import.meta.env.RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI';

// SEO optimized titles and descriptions based on keyword research
const seoData = {
  title: "Desarrolladora WordPress Freelance en Barcelona | RimoByte",
  description: "Creo webs en WordPress para autónomos y negocios en Barcelona. Diseño personalizado, precios claros desde 500€ y sin sorpresas. Pide presupuesto gratis."
};

const currentSeo = seoData;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta una página web?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depende del tipo de proyecto. Una web corporativa parte desde 500 €, una tienda online desde 1.200 € y una aplicación web desde 2.500 €. Te doy un presupuesto detallado antes de empezar, sin sorpresas." }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tarda un proyecto web?",
      "acceptedAnswer": { "@type": "Answer", "text": "Una landing page puede estar lista en 1-2 semanas. Una web corporativa en 3-4 semanas. Una tienda online en 4-6 semanas. Los plazos exactos dependen del alcance, pero siempre los acordamos antes de empezar." }
    },
    {
      "@type": "Question",
      "name": "¿Trabajas solo con WordPress?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. WordPress es una de mis especialidades para webs corporativas y tiendas online, pero también trabajo con Vue, Nuxt, Astro y Shopify para proyectos que necesitan otro enfoque." }
    },
    {
      "@type": "Question",
      "name": "¿Colaboras con estudios de desarrollo o agencias?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Aporto refuerzo técnico en WordPress y en otros stacks cuando necesitáis capacidad extra o un perfil puntual, además de trabajar con clientes finales directamente." }
    },
    {
      "@type": "Question",
      "name": "¿Puedo mantener la web yo después?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todas las webs están pensadas para que puedas gestionar contenidos fácilmente. Además, ofrezco mantenimiento mensual si prefieres no ocuparte de la parte técnica." }
    },
    {
      "@type": "Question",
      "name": "¿Trabajas en remoto?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Trabajo en remoto con clientes en toda España. La comunicación es directa por email, WhatsApp o videollamada, según prefieras." }
    },
    {
      "@type": "Question",
      "name": "¿Qué incluye el mantenimiento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Actualizaciones de WordPress y plugins, copias de seguridad, monitoreo de seguridad y soporte técnico para resolver cualquier incidencia. Desde 40 €/mes." }
    }
  ]
};
---

<MainLayout 
  title={currentSeo.title}
  description={currentSeo.description}
>
  <AggregateRatingSchema rating={4.9} reviewCount={12} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <MainPage client:only="react" recaptchaSiteKey={recaptchaSiteKey} />
</MainLayout>
