---
import MainLayout from '@/layouts/MainLayout.astro';
import AggregateRatingSchema from '@/components/schema/AggregateRatingSchema.astro';
import MainPage from '@/components/MainPage';
import { LANG } from '@/i18n/index';

// Get reCAPTCHA site key from environment variable
// Site key is public and safe to expose to the client
const recaptchaSiteKey = import.meta.env.RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI';

// SEO optimized titles and descriptions based on keyword research
const seoData = {
  es: {
    title: "Desarrolladora Web Freelance en España | WordPress, Tiendas Online, Apps Web | RimoByte",
    description: "Desarrollo web profesional para pymes y autónomos en España. WordPress, tiendas online y aplicaciones web a medida. Precios claros desde 500 €, sin agencias ni sorpresas."
  },
  en: {
    title: "Freelance Web Developer in Spain | WordPress, E-commerce, Web Apps | RimoByte",
    description: "Professional web development for SMBs and freelancers in Spain. WordPress, online stores, and custom web apps. Clear pricing from €500, no agencies or surprises."
  }
};

const currentSeo = seoData.es;
---

<MainLayout 
  title={currentSeo.title}
  description={currentSeo.description}
  locale={LANG.SPANISH}
>
  <AggregateRatingSchema rating={4.9} reviewCount={12} />
  <MainPage client:only="react" recaptchaSiteKey={recaptchaSiteKey} initialLocale={LANG.SPANISH} />
</MainLayout>
