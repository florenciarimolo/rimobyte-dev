---
import MainLayout from '@/layouts/MainLayout.astro';
import LandingBackground from '@/components/LandingBackground.astro';
import ServiceLandingNavbar from '@/components/ServiceLandingNavbar.astro';
import ServiceLandingFooter from '@/components/ServiceLandingFooter.astro';
import { LANG, getI18N } from '@/i18n/index';
import { SITE_URL } from '@/constants';

const locale = LANG.SPANISH;
const translations = getI18N({ currentLocale: locale });
const currentUrl = `${SITE_URL}${Astro.url.pathname}`;

const title = translations.redesignLanding.title;
const description = translations.redesignLanding.description;
const keywords = translations.redesignLanding.keywords;

// ProfessionalService Schema with Offers
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "RimoByte - Rediseño Web WordPress",
  "url": currentUrl,
  "description": "Moderniza tu sitio web WordPress sin perder posicionamiento SEO. Diseño actualizado manteniendo todo tu tráfico.",
  "provider": {
    "@type": "Person",
    "name": "Florencia Rímolo",
    "jobTitle": "Desarrolladora Full Stack"
  },
  "areaServed": { "@type": "Country", "name": "Spain" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Rediseño Web WordPress",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rediseño Web WordPress", "description": "Rediseño completo manteniendo SEO. Incluye diseño mobile-first, velocidad optimizada, mejor UX y 30 días soporte." }, "priceSpecification": { "@type": "PriceSpecification", "minPrice": "600", "priceCurrency": "EUR" } }
    ]
  }
};

// FAQ Schema for AI discoverability
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta rediseñar una web WordPress?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El rediseño web WordPress en RimoByte empieza desde 600 €, dependiendo del número de páginas y funcionalidades. Incluye backup completo, formación para gestionar el nuevo diseño, 30 días de soporte y garantía: si pierdes SEO, lo recupero gratis."
      }
    },
    {
      "@type": "Question",
      "name": "¿Pierdo posicionamiento SEO al rediseñar mi web?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. El proceso de rediseño de RimoByte está diseñado para mantener todas las URLs y posicionamiento existente. Se realiza una migración SEO-safe que preserva rankings y tráfico. Incluye garantía: si pierdes SEO, lo recupero gratis."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuándo necesito rediseñar mi web?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Necesitas un rediseño si tu web tiene más de 3-4 años, no se ve bien en móvil, la velocidad es muy lenta, la tasa de conversión es baja, has cambiado de marca, o no puedes hacer cambios fácilmente."
      }
    }
  ]
};
---

<MainLayout 
  title={title}
  description={description}
  keywords={keywords}
  locale={locale}
  canonical={currentUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <LandingBackground />
  <ServiceLandingNavbar locale={locale} />
  <main class="relative py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <header class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          Rediseño Web WordPress
        </h1>
        <div class="w-24 h-1 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto mb-6"></div>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
          Moderniza tu sitio web sin perder posicionamiento. Diseño actualizado manteniendo todo tu SEO y tráfico.
        </p>
      </header>

      <section class="grid md:grid-cols-2 gap-8 mb-20">
        <div class="bg-white/80 dark:bg-black/40 backdrop-blur-md rounded-xl p-8 border border-gray-200 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">¿Cuándo necesitas un rediseño?</h2>
          <ul class="space-y-4">
            {['Diseño anticuado (más de 3-4 años)', 'No se ve bien en móvil', 'Velocidad muy lenta', 'Tasa de conversión baja', 'Cambio de identidad de marca', 'No puedes hacer cambios fácilmente'].map((item) => (
              <li class="flex items-start gap-3 text-gray-600 dark:text-gray-300">
                <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white/80 dark:bg-black/40 backdrop-blur-md rounded-xl p-8 border border-gray-200 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Mi proceso de rediseño</h2>
          <div class="space-y-4">
            {[
              { title: '1. Auditoría completa', desc: 'Analizo tu web actual, SEO, velocidad y conversión' },
              { title: '2. Propuesta de diseño', desc: 'Mockups y estructura nueva con tu feedback' },
              { title: '3. Desarrollo', desc: 'Implemento el nuevo diseño en entorno de pruebas' },
              { title: '4. Migración SEO-safe', desc: 'Publico manteniendo URLs y posicionamiento' }
            ].map((step) => (
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">{step.title}</h3>
                <p class="text-gray-500 dark:text-gray-400">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-12">Qué incluye el rediseño</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: 'Diseño moderno', desc: 'Adaptado a tendencias actuales y tu marca', icon: '🎨' },
            { title: 'Mobile-first', desc: 'Optimizado para móviles y tablets', icon: '📱' },
            { title: 'Velocidad optimizada', desc: 'Mínimo 30 puntos mejora PageSpeed', icon: '⚡' },
            { title: 'SEO mantenido', desc: 'Sin perder rankings ni tráfico', icon: '📈' },
            { title: 'Mejor UX', desc: 'Navegación intuitiva y clara', icon: '✨' },
            { title: 'Conversión mejorada', desc: 'CTAs optimizados para ventas', icon: '💰' }
          ].map((feature) => (
            <div class="bg-white/80 dark:bg-black/40 backdrop-blur-md rounded-xl p-6 border border-gray-200 dark:border-gray-800 hover:border-blue-500 transition-all duration-300 text-center">
              <div class="text-4xl mb-4">{feature.icon}</div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">{feature.title}</h3>
              <p class="text-gray-600 dark:text-gray-300">{feature.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-16">
        <div class="bg-white/80 dark:bg-black/40 backdrop-blur-md rounded-xl p-8 border border-blue-500/30">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-6">Precio del Rediseño</h2>
          <div class="text-center mb-6">
            <div class="text-4xl font-bold text-blue-400 mb-2">Desde 600€</div>
            <p class="text-gray-600 dark:text-gray-300">Precio final según páginas y funcionalidades</p>
          </div>
          <div class="grid md:grid-cols-2 gap-4 text-sm text-gray-500 dark:text-gray-400">
            <div>✓ Backup completo antes de empezar</div>
            <div>✓ Formación para gestionar el nuevo diseño</div>
            <div>✓ 30 días de soporte post-lanzamiento</div>
            <div>✓ Garantía: si pierdes SEO, lo recupero gratis</div>
          </div>
        </div>
      </section>

      <section class="text-center">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4 pt-12">¿Tu web necesita un cambio de imagen?</h2>
          <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">Te hago una auditoría gratuita y propuesta de rediseño</p>
          <a 
            href="https://wa.me/34684713743?text=Hola,%20quiero%20información%20sobre%20rediseño%20web"
            class="inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-lg font-bold text-xl hover:from-blue-600 hover:to-purple-600 transform hover:scale-105 transition-all duration-300 shadow-2xl"
          >
            Solicitar Auditoría Gratuita
          </a>
      </section>

    </div>
  </main>
  <ServiceLandingFooter locale={locale} />
</MainLayout>
