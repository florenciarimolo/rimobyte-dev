---
import MainLayout from '@/layouts/MainLayout.astro';
import MigrationLandingPage from '@/components/MigrationLandingPage';
import MigrationStructuredData from '@/components/migration-landing/MigrationStructuredData.astro';
import { SITE_URL } from '@/constants';
import { isValidCity, getCityInfo, indexableCities, getAllowedCities } from '@/constants/cities';

export function getStaticPaths() {
  const cities = getAllowedCities();
  return Object.keys(cities).map((city) => ({ params: { city } }));
}

const { city } = Astro.params;

const normalizedCity = city?.toLowerCase();
const isValidCitySlug = normalizedCity && isValidCity(normalizedCity);

if (!isValidCitySlug) {
  return Astro.redirect('/404');
}

const cityInfo = getCityInfo(normalizedCity!);
const cityName = cityInfo!.name;
const isIndexable = indexableCities.includes(normalizedCity!);

const currentUrl = `${SITE_URL}${Astro.url.pathname}`;
const title = `Migración WordPress en ${cityName} | Sin perder SEO ni contenido | Desde 400€`;
const description = `Migración segura de WordPress en ${cityName}. Cambio de hosting, dominio o plataforma sin perder posicionamiento. Freelance con 5 años de experiencia. Desde 400€.`;
---

<MainLayout 
  title={title}
  description={description}
  city={cityName}
>
  <meta name="robots" content={isIndexable ? "index, follow" : "noindex, follow"} />
  
  <MigrationStructuredData 
    url={currentUrl}
    city={cityName}
    cityInfo={cityInfo}
  />
  <MigrationLandingPage 
    client:only="react" 
    cityName={cityName}
    recaptchaSiteKey={import.meta.env.RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI'}
  />
</MainLayout>
