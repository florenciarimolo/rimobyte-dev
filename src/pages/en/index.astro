---
import MainLayout from '@/layouts/MainLayout.astro';
import AggregateRatingSchema from '@/components/schema/AggregateRatingSchema.astro';
import MainPage from '@/components/MainPage';
import { LANG } from '@/i18n/index';

// Get reCAPTCHA site key from environment variable
// Site key is public and safe to expose to the client
const recaptchaSiteKey = import.meta.env.RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI';

// SEO optimized titles and descriptions for English
const seoData = {
  title: "Freelance Web Developer in Spain | WordPress, E-commerce, Web Apps | RimoByte",
  description: "Professional web development for SMBs and freelancers in Spain. WordPress, online stores, and custom web apps. Clear pricing from €500, no agencies or surprises."
};
---

<MainLayout 
  title={seoData.title}
  description={seoData.description}
  locale={LANG.ENGLISH}
>
  <AggregateRatingSchema rating={4.9} reviewCount={12} name="RimoByte - Freelance Web Development" />
  <MainPage client:only="react" recaptchaSiteKey={recaptchaSiteKey} initialLocale={LANG.ENGLISH} />
</MainLayout>

