---
import MainLayout from '@/layouts/MainLayout.astro';
import WordPressLandingPage from '@/components/WordPressLandingPage';
import WordPressStructuredData from '@/components/wordpress-landing/WordPressStructuredData.astro';
import { getI18N } from '@/i18n/index';
import { SITE_URL } from '@/constants';

const translations = getI18N();

const currentUrl = `${SITE_URL}${Astro.url.pathname}`;
const title = 'Desarrolladora WordPress Freelance en Barcelona | RimoByte';
const description =
  'Desarrolladora WordPress freelance en Barcelona. Webs profesionales para autónomos y negocios desde 700€, entregadas en plazo y sin sorpresas. Pide presupuesto gratis.';

// Get reCAPTCHA site key from environment variable
const recaptchaSiteKey = import.meta.env.RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI';

// FAQ Schema for AI discoverability
const faqItems = [
  { question: translations.wordpressLanding.faq.items.onlyWordPress.question, answer: translations.wordpressLanding.faq.items.onlyWordPress.answer },
  { question: translations.wordpressLanding.faq.items.freelanceOrAgency.question, answer: translations.wordpressLanding.faq.items.freelanceOrAgency.answer },
  { question: translations.wordpressLanding.faq.items.canMaintain.question, answer: translations.wordpressLanding.faq.items.canMaintain.answer },
  { question: translations.wordpressLanding.faq.items.smallBusinesses.question, answer: translations.wordpressLanding.faq.items.smallBusinesses.answer },
];
---

<MainLayout 
  title={title}
  description={description}
>
  <WordPressStructuredData url={currentUrl} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  })} />
  <WordPressLandingPage client:only="react" recaptchaSiteKey={recaptchaSiteKey} />
</MainLayout>
